# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=      # https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY= # Settings → API → anon/public key
SUPABASE_SERVICE_ROLE_KEY=     # Settings → API → service_role key
FAMILY_ID=                     # UUID de la fila en families

# ── Telegram Webhook ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=            # BotFather → /mybots → API Token
TELEGRAM_WEBHOOK_SECRET=       # Cadena aleatoria para verificar llamadas de Telegram
                                # Genera con: openssl rand -hex 32

# ── AI APIs ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=                # Google AI Studio → API Keys
ANTHROPIC_API_KEY=             # console.anthropic.com → API Keys (para suggest_menu)
OPENAI_API_KEY=                # platform.openai.com → API Keys (para Whisper STT)

# ── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET=                   # Cadena aleatoria; Vercel la envía en Authorization: Bearer <secret>
                                # Genera con: openssl rand -hex 32

# ── Opcional ─────────────────────────────────────────────────────────────────
TIMEZONE=Europe/Madrid         # Zona horaria para fechas en respuestas de JARVIS
