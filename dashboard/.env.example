# ── Required ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=      # https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY= # Settings → API → anon/public key

# ── Required for Server Components (service role) ───────────────────────────
# Set in Vercel → Project Settings → Environment Variables (NOT in .env.local for prod)
SUPABASE_SERVICE_ROLE_KEY=     # Settings → API → service_role key
FAMILY_ID=                     # UUID de la fila en families
