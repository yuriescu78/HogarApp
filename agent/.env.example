# ── Required ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # @BotFather token
SUPABASE_URL=                # https://<project>.supabase.co  (local: http://127.0.0.1:54321)
SUPABASE_SERVICE_ROLE_KEY=   # Settings → API → service_role (NEVER expose en cliente)
GEMINI_API_KEY=              # Google AI Studio → gemini-2.5-flash + text-embedding-004
FAMILY_ID=                   # UUID de la fila en families

# ── Required for voice + menu AI ────────────────────────────────────────────
OPENAI_API_KEY=              # Whisper STT para mensajes de voz
ANTHROPIC_API_KEY=           # Claude Sonnet para suggest_menu

# ── Optional ─────────────────────────────────────────────────────────────────
TIMEZONE=Europe/Madrid       # Zona horaria para cron jobs y fechas
GOOGLE_TTS_CREDENTIALS=      # Ruta al JSON de service account (Google Cloud TTS, fase futura)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
